            }
          },
          "order_by": { "type": "string" }
        },
        "required": ["table", "filters", "order_by"],
        "additionalProperties": false
      }
    },
    "needs_rag": {
      "type": "boolean"
    }
  },
  "required": ["queries", "needs_rag"],
