            "items": {
              "type": "object",
              "properties": {
                "field": { "type": "string" },
                "op": { "type": "string", "enum": ["=", "!=", ">", "<", ">=", "<=", "IN", "NOT IN", "LIKE"] },
                "value": {
                  "anyOf": [
