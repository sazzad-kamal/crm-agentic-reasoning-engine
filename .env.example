# =============================================================================
# CRM Agentic Reasoning Engine - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values

# OpenAI API Key (required for answer synthesis, embeddings)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Anthropic API Key (required for SQL generation)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Mock LLM mode - set to "1" to use mock responses (no API key needed)
# Useful for development and testing
MOCK_LLM=0

# Frontend API URL (optional, defaults to http://localhost:8000)
# VITE_API_URL=http://localhost:8000

# =============================================================================
# Backend API Configuration (optional)
# =============================================================================
# All settings have sensible defaults. Override as needed.

# Show detailed error messages (set to true for local development)
# ACME_DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR
# ACME_LOG_LEVEL=INFO

# Log each HTTP request to console
# ACME_LOG_REQUESTS=true

# =============================================================================
# RAG Pipeline Configuration (optional)
# =============================================================================
# These settings control the RAG (Retrieval-Augmented Generation) pipeline.
# Defaults are optimized for low latency. Enable for higher quality at cost of speed.

# HyDE (Hypothetical Document Embeddings) - generates a hypothetical answer
# to improve semantic search. Adds ~2-3s latency.
# AGENT_RAG_USE_HYDE=false

# Query Rewriting - rewrites the query for better retrieval. Adds ~1-2s latency.
# AGENT_RAG_USE_REWRITE=false

# Reranker - reorders results for better relevance. Recommended to keep enabled.
# AGENT_RAG_USE_RERANKER=true

# =============================================================================
# Neo4j Graph Database (optional - for multi-hop relationship queries)
# =============================================================================
# Local: docker compose up neo4j
# Production: Neo4j Aura (https://neo4j.com/cloud/aura/)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=testpassword

# =============================================================================
# LangSmith Tracing (optional - for debugging agent flows)
# =============================================================================
# Sign up at: https://smith.langchain.com
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_pt_your-key-here
# LANGCHAIN_PROJECT=acme-crm-companion
